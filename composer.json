{
  "name": "jan-made/sentry",
  "description": "Sentry integration into Nette framework",
  "keywords": [
    "nette",
    "contributte",
    "sentry",
    "php"
  ],
  "type": "library",
  "license": "MIT",
  "homepage": "https://github.com/jan-made/sentry",
  "authors": [
    {
      "name": "Jan Trejbal",
      "homepage": "https://github.com/jan-made"
    }
  ],
  "replace": {
    "trejjam/sentry": "self.version"
  },
  "require": {
    "php": "^8.2 || ^8.3 || ^8.4 || ^8.5",
    "nette/di": "^3.2.5",
    "nette/schema": "^1.3.5",
    "sentry/sentry": "^4.23.0"
  },
  "require-dev": {
    "http-interop/http-factory-guzzle": "^1.2.1",
    "contributte/qa": "^0.3.2 || ^0.4.0",
    "contributte/tester": "^0.4.1",
    "nette/tester": "^2.6.0",
    "phpstan/extension-installer": "^1.4.3",
    "phpstan/phpstan": "^2.1.45",
    "phpstan/phpstan-deprecation-rules": "^2.0.4",
    "phpstan/phpstan-nette": "^2.0.9",
    "phpstan/phpstan-strict-rules": "^2.0.10",
    "tracy/tracy": "^2.11.3"
  },
  "suggest": {
    "http-interop/http-factory-guzzle": "Recomended Guzzle HTTP Factory",
    "tracy/tracy": "To use SentryLogger"
  },
  "autoload": {
    "psr-4": {
      "Trejjam\\Sentry\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\Fixtures\\": "tests/fixtures"
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "phpstan/extension-installer": true
    }
  },
  "extra": {
    "branch-alias": {
      "dev-master": "0.4.x-dev"
    }
  }
}
